# ─────────────────────────────────────────────────────────────────────────────
# Cognitive Load Router — Environment Variables
# Copy this file to .env (never commit .env) and fill in your values.
# All variables use the CLR_ prefix and map directly to engine/config.py fields.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use local SQLite (desktop dev mode).
# Set to a PostgreSQL URL for hosted/production deployments.
# Railway provides this automatically when you add a Postgres plugin.
CLR_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
CLR_JWT_SECRET=replace-this-with-a-strong-random-secret
CLR_JWT_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your Railway domain after first deploy, and your Capacitor app origin.
# Example:
#   https://your-app.railway.app,capacitor://localhost,http://localhost:5173
CLR_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,null

# ── API Server ────────────────────────────────────────────────────────────────
# On Railway, PORT is injected automatically — do not set it manually there.
# For local dev, these defaults are used if not overridden.
CLR_API_HOST=127.0.0.1
CLR_API_PORT=8765

# ── Inference ─────────────────────────────────────────────────────────────────
CLR_INFERENCE_INTERVAL_MS=2000
CLR_LOAD_HISTORY_WINDOW_S=300

# ── Action Thresholds ─────────────────────────────────────────────────────────
CLR_HIGH_LOAD_THRESHOLD=0.75
CLR_FATIGUE_THRESHOLD=0.85
CLR_LOW_LOAD_THRESHOLD=0.35
