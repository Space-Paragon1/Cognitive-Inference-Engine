<?xml version="1.0" encoding="utf-8"?>
<!--
  Window background shown immediately on cold start, before Capacitor loads.
  Uses the app's deep-navy background with the branded icon centred.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Dark background matching the web app (#0d0d1f) -->
    <item>
        <color android:color="#0d0d1f" />
    </item>

    <!-- Centred icon (96 × 96 dp) -->
    <item
        android:width="96dp"
        android:height="96dp"
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_foreground" />

</layer-list>
